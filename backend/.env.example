PORT=5000
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,https://your-vercel-app.vercel.app
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
MONGODB_URI=mongodb+srv://kavachadmin:YOUR_PASSWORD@cluster0.uryqeds.mongodb.net/kavach_workflow_management?retryWrites=true&w=majority&appName=Cluster0
ADMIN_REGISTRATION_SECRET=KavachAdmin@2026
# Choose: cloudinary, local, or auto.
UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=kavach

# Password reset email. Use your SMTP provider's credentials in Render.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Optional: defaults to the first CLIENT_URLS address and appends /reset-password.
PASSWORD_RESET_URL=
